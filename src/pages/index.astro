---
import Contact from "../components/Contact.astro";
import LandingHeader from "../components/LandingHeader.astro";
import Solutions from "../components/Solutions.astro";
import Service from "../components/Service.astro";
import Products from "../components/Products.astro";
import About from "../components/About.astro";
import Production from "../components/Production.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Metalico">
  <main
    class="snap-y snap-mandatory snap-always h-screen overflow-y-scroll overflow-x-hidden"
  >
    <div class="snap-start">
      <section id="home" class="landing-section relative h-screen w-screen bg-black" data-header-color="white">
        <div class="absolute inset-0 h-full w-full">
          <img class="h-full w-full object-cover object-center" src="home.avif" alt="Maquila metalmecánica" />
        </div>
        <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70 z-10"></div>
        <div class="absolute top-0 left-0 right-0 z-30">
          <LandingHeader />
        </div>
        <div class="absolute inset-0 z-20 flex flex-col items-center justify-center text-white px-4">
          <img class="h-24 md:h-32 mb-6" src="/logo_metalico.png" alt="Metalico" />
          <h1 class="text-3xl md:text-5xl font-bold text-center max-w-3xl">
            Maquila metalmecánica e inyección de plástico
          </h1>
          <p class="text-lg md:text-xl mt-4 text-center max-w-xl text-gray-200">
            Consolidamos proyectos con tecnología metalúrgica de vanguardia
          </p>
          <a href="#contact" class="mt-10 bg-yellow-400 text-black font-semibold px-10 py-3 rounded text-lg transition-colors hover:bg-yellow-300">
            Cotizar servicio
          </a>
        </div>
      </section>
    </div>
    <div class="snap-start">
      <About />
    </div>
    <div class="snap-start">
      <Service />
    </div>
    <div class="snap-start">
      <Products />
    </div>
    <div class="snap-start">
      <Solutions />
    </div>
    <div class="snap-start">
      <Production />
    </div>
    <div class="snap-start">
      <Contact />
    </div>
    <button id="btn-subir" class="fixed bottom-6 right-6 z-50 bg-yellow-400 text-black w-12 h-12 rounded-full shadow-lg flex items-center justify-center text-2xl font-bold transition-all duration-300 hover:bg-yellow-300 hover:scale-110 opacity-0 pointer-events-none" onclick="document.querySelector('main').scrollTo({ top: 0, behavior: 'smooth' })" aria-label="Volver arriba">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3" stroke-linecap="round"><path d="M18 15l-6-6-6 6"/></svg>
    </button>
  </main>
</Layout>

<script>
  const btn = document.getElementById('btn-subir');
  const main = document.querySelector('main');
  main.addEventListener('scroll', function () {
    if (main.scrollTop > window.innerHeight * 0.5) {
      btn.classList.remove('opacity-0', 'pointer-events-none');
      btn.classList.add('opacity-100');
    } else {
      btn.classList.add('opacity-0', 'pointer-events-none');
      btn.classList.remove('opacity-100');
    }
  });
</script>
