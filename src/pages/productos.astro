---
import Layout from "../layouts/Layout.astro";
import { getCollectionProducts } from "../lib/shopify.js";

const storeDomain = import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN;
const COLLECTION_ID = "496485990703";
const products = await getCollectionProducts(COLLECTION_ID, 50);

function formatPrice(amount, currency) {
  return new Intl.NumberFormat("es-MX", {
    style: "currency",
    currency,
  }).format(amount);
}
---

<Layout title="Tienda — Metalico" description="Explora nuestros productos manufacturados">
  <header class="flex items-center justify-between px-[5%] py-4">
    <a href="/" class="flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Volver al inicio
    </a>
    <h1 class="text-xl font-semibold text-gray-900">Tienda Metalico</h1>
    <div class="w-20"></div>
  </header>

  <main class="max-w-7xl mx-auto px-4 pb-16">
    <div class="flex justify-end mb-4">
      <select id="sort-select" class="text-sm border border-gray-300 rounded px-3 py-1.5 text-gray-700 bg-white cursor-pointer">
        <option value="default">Ordenar por</option>
        <option value="price-asc">Precio: menor a mayor</option>
        <option value="price-desc">Precio: mayor a menor</option>
      </select>
    </div>

    <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {products.map((p) => {
        const price = p.priceRange.minVariantPrice;
        const image = p.images.edges[0]?.node;
        const variant = p.variants.edges[0]?.node;
        const shopUrl = `https://${storeDomain}/products/${p.handle}`;
        const desc = p.description ? p.description.slice(0, 90) + (p.description.length > 90 ? "…" : "") : "";
        return (
          <div
            class="product-card group border border-gray-100 rounded-lg overflow-hidden hover:shadow-md transition-shadow"
            data-price={price.amount}
          >
            <a href={shopUrl} target="_blank" rel="noopener noreferrer" class="block">
              <div class="relative pt-[75%] bg-gray-50">
                {image && (
                  <img
                    src={image.url}
                    alt={image.altText || p.title}
                    class="absolute inset-0 w-full h-full object-cover"
                    loading="lazy"
                  />
                )}
              </div>
            </a>
            <div class="p-3 flex flex-col gap-1.5">
              {p.productType && (
                <span class="text-[10px] uppercase tracking-wider text-yellow-600 font-semibold">{p.productType}</span>
              )}
              <a href={shopUrl} target="_blank" rel="noopener noreferrer">
                <h3 class="text-sm text-gray-800 font-semibold line-clamp-2 hover:text-yellow-600 transition-colors">{p.title}</h3>
              </a>
              {desc && (
                <p class="text-xs text-gray-500 line-clamp-2">{desc}</p>
              )}
              <div class="flex items-baseline gap-2 mt-0.5">
                {variant?.compareAtPrice && parseFloat(variant.compareAtPrice.amount) > parseFloat(price.amount) && (
                  <span class="text-xs text-gray-400 line-through">{formatPrice(variant.compareAtPrice.amount, variant.compareAtPrice.currencyCode)}</span>
                )}
                <p class="text-base font-bold" style="color:#ff8308">
                  {formatPrice(price.amount, price.currencyCode)}
                </p>
              </div>
              {variant?.sku && (
                <span class="text-[10px] text-gray-400">SKU: {variant.sku}</span>
              )}
              <a
                href={shopUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-1 inline-block w-full text-center border-2 border-white bg-stone-600 text-sm rounded font-medium text-white px-4 py-2 opacity-0 group-hover:opacity-100 transition-all hover:bg-yellow-400 hover:text-black hover:border-yellow-400 hover:scale-[1.02]"
              >
                Comprar
              </a>
              {!p.availableForSale && (
                <span class="block text-center text-xs text-red-500">Agotado</span>
              )}
            </div>
          </div>
        );
      })}
    </div>

    {products.length === 0 && (
      <p class="text-center text-gray-500 py-16">No hay productos disponibles en este momento.</p>
    )}
  </main>

  <footer class="bg-stone-600 text-gray-300">
    <div class="max-w-7xl mx-auto px-4 py-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <div>
        <h3 class="text-white font-semibold text-lg mb-3">Métodos de pago</h3>
        <ul class="space-y-2 text-sm">
          <li class="flex items-center gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block"></span>Tarjetas de débito / crédito (Visa, MasterCard)</li>
          <li class="flex items-center gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block"></span>Transferencia bancaria / SPEI</li>
          <li class="flex items-center gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block"></span>PayPal</li>
          <li class="flex items-center gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block"></span>Pago en tienda (previo acuerdo)</li>
        </ul>
        <p class="text-xs text-gray-500 mt-2">* Los métodos disponibles se confirmarán al finalizar la compra.</p>
      </div>
      <div>
        <h3 class="text-white font-semibold text-lg mb-3">Políticas de compra</h3>
        <ul class="space-y-2 text-sm">
          <li class="flex items-start gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block mt-1.5 shrink-0"></span>Los precios pueden variar sin previo aviso.</li>
          <li class="flex items-start gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block mt-1.5 shrink-0"></span>Las compras se procesan a través de Shopify, plataforma segura.</li>
          <li class="flex items-start gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block mt-1.5 shrink-0"></span>Facturación: envía tu solicitud a contacto@metalico.mx.</li>
        </ul>
      </div>
      <div>
        <h3 class="text-white font-semibold text-lg mb-3">Envíos</h3>
        <ul class="space-y-2 text-sm">
          <li class="flex items-start gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block mt-1.5 shrink-0"></span>Envío a toda la República Mexicana.</li>
          <li class="flex items-start gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block mt-1.5 shrink-0"></span>Tiempo estimado de entrega: 5–10 días hábiles.</li>
          <li class="flex items-start gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block mt-1.5 shrink-0"></span>El costo de envío se calcula al momento del pago.</li>
          <li class="flex items-start gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block mt-1.5 shrink-0"></span>Recogida en taller disponible (previa cita).</li>
        </ul>
      </div>
      <div>
        <h3 class="text-white font-semibold text-lg mb-3">Contacto</h3>
        <ul class="space-y-2 text-sm">
          <li><span class="block text-gray-400 text-xs">Correo</span><a href="mailto:contacto@metalico.mx" class="hover:text-white transition-colors">contacto@metalico.mx</a></li>
          <li><span class="block text-gray-400 text-xs">Teléfono</span><a href="tel:+525581082193" class="hover:text-white transition-colors">55 8108 2193</a></li>
          <li><span class="block text-gray-400 text-xs">WhatsApp</span><a href="https://wa.me/525581082193" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">55 8108 2193</a></li>
        </ul>
        <div class="mt-4">
          <a href="/privacidad" class="text-xs text-gray-500 hover:text-white underline transition-colors">Política de privacidad</a>
        </div>
      </div>
    </div>
    <div class="border-t border-gray-800">
      <p class="text-center text-xs text-gray-600 py-4">&copy; 2026 Metalico. Todos los derechos reservados.</p>
    </div>
  </footer>
</Layout>

<script>
  const sortSelect = document.getElementById("sort-select");
  const grid = document.getElementById("product-grid");

  sortSelect?.addEventListener("change", function () {
    const order = this.value;
    const cards = Array.from(grid.querySelectorAll(".product-card"));
    if (order === "default") return;

    cards.sort((a, b) => {
      const pa = parseFloat(a.dataset.price);
      const pb = parseFloat(b.dataset.price);
      return order === "price-asc" ? pa - pb : pb - pa;
    });

    cards.forEach((c) => grid.appendChild(c));
  });
</script>