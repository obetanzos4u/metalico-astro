      }).then(function () {
        setTimeout(function () {
          function walkShadow(root) {
            root.querySelectorAll('*').forEach(function (el) {
              var t = el.textContent.trim();
              if (t === 'Next page' || t === 'Previous page') {
                el.textContent = t === 'Next page' ? 'Ver más' : 'Anterior';
              }
            });
            root.querySelectorAll('*').forEach(function (host) {
              if (host.shadowRoot) walkShadow(host.shadowRoot);
            });
          }
          walkShadow(document);

          var container = document.getElementById('collection-component-1783555392245');
          if (container && container.firstElementChild && container.firstElementChild.shadowRoot) {
            var btn = container.firstElementChild.shadowRoot.querySelector('[class*="pagination"]');
            if (btn) btn.textContent = 'Ver más';
          }
        }, 1000);
      });
