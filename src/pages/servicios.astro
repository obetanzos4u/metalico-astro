---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Servicios — Metalico" description="Acabados metálicos, tratamientos superficiales e inyección de plástico — diseño, desarrollo y manufactura">
  <section class="relative h-[50vh] min-h-[350px] max-h-[420px] flex items-center justify-center overflow-hidden">
    <img src="bg-machine.avif" alt="" class="absolute inset-0 h-full w-full object-cover object-center" />
    <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/50 to-black/70"></div>
    <header class="absolute top-0 left-0 right-0 flex items-center justify-between px-[5%] py-4 z-10 bg-niebla-700">
      <a href="/" onclick="event.preventDefault(); history.back()" class="flex items-center gap-2 text-sm font-medium text-gray-200 hover:text-white transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Volver al inicio
      </a>
      <div class="flex items-center justify-center">
        <img src="/logo_metalico.avif" alt="Metalico" class="h-8" onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
        <span class="text-xl font-semibold text-white hidden">Metalico</span>
      </div>
      <div class="w-20"></div>
    </header>
    <div class="relative z-10 text-center px-4">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Servicios Especializados</h1>
      <p class="text-lg text-[#e7e7e7] max-w-2xl mx-auto">Acabados metálicos, tratamientos superficiales e inyección de plástico — diseño, desarrollo y manufactura con más de 20 años de experiencia.</p>
    </div>
  </section>

  <main class="max-w-6xl mx-auto px-4 py-16">

    <!-- Materiales -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold text-gray-900 mb-2">Materiales que trabajamos</h2>
      <p class="text-gray-600 mb-8">Procesamos una amplia variedad de metales para adaptarnos a las necesidades de cada proyecto.</p>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        <div class="bg-gray-50 rounded-xl p-4 text-center border border-gray-200">
          <span class="text-sm font-semibold text-gray-900">Acero al carbón</span>
        </div>
        <div class="bg-gray-50 rounded-xl p-4 text-center border border-gray-200">
          <span class="text-sm font-semibold text-gray-900">Acero inoxidable</span>
        </div>
        <div class="bg-gray-50 rounded-xl p-4 text-center border border-gray-200">
          <span class="text-sm font-semibold text-gray-900">Latón</span>
        </div>
        <div class="bg-gray-50 rounded-xl p-4 text-center border border-gray-200">
          <span class="text-sm font-semibold text-gray-900">Cobre</span>
        </div>
        <div class="bg-gray-50 rounded-xl p-4 text-center border border-gray-200">
          <span class="text-sm font-semibold text-gray-900">Aceros tratados</span>
        </div>
      </div>
    </section>

    <!-- Capacidades de corte -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold text-gray-900 mb-2">Capacidades de corte</h2>
      <p class="text-gray-600 mb-8">Equipo especializado para procesar piezas en diversos espesores y perfiles.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Corte láser</h3>
          <p class="text-sm text-gray-600">Capacidad de ½" a Calibre 30, con alta precisión y velocidad en una amplia gama de espesores.</p>
        </div>
        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Cortadora</h3>
          <p class="text-sm text-gray-600">Capacidad de hasta ¼" para cortes precisos en placa y lámina.</p>
        </div>
        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Perfiles estructurales</h3>
          <p class="text-sm text-gray-600">Procesamos Barra 5/4", Ángulo ¼" y Solera ¼" para aplicaciones estructurales y de manufactura.</p>
        </div>
      </div>
    </section>

    <!-- Acabados Metálicos -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold text-gray-900 mb-2">Acabados Metálicos</h2>
      <p class="text-gray-600 mb-8">Protegemos y mejoramos tus piezas con procesos industriales especializados.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
          <div class="w-12 h-12 bg-yellow-400 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Galvanizado por inmersión en caliente</h3>
          <p class="text-sm text-gray-600">Recubrimiento de zinc fundido para protección máxima contra la corrosión en exteriores e industrias agresivas.</p>
        </div>

        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
          <div class="w-12 h-12 bg-yellow-400 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Zincado electrolítico</h3>
          <p class="text-sm text-gray-600">Capa fina y uniforme de zinc mediante proceso electrolítico, ideal para piezas con tolerancias precisas.</p>
        </div>

        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
          <div class="w-12 h-12 bg-yellow-400 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Pintura electrostática</h3>
          <p class="text-sm text-gray-600">Aplicación de pintura en polvo con curado en horno para acabados resistentes a golpes, rayones y químicos.</p>
        </div>

        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
          <div class="w-12 h-12 bg-yellow-400 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Tropicalizado</h3>
          <p class="text-sm text-gray-600">Tratamiento anticorrosivo especial para ambientes de alta humedad, salinidad y condiciones tropicales extremas.</p>
        </div>

        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
          <div class="w-12 h-12 bg-yellow-400 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Pavonado</h3>
          <p class="text-sm text-gray-600">Tratamiento químico que genera una capa de óxido negro para protección contra la corrosión ligera y acabado estético.</p>
        </div>

        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
          <div class="w-12 h-12 bg-yellow-400 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Pintura de aceite</h3>
          <p class="text-sm text-gray-600">Aplicación de pintura líquida convencional para acabados industriales de alto rendimiento.</p>
        </div>
      </div>
    </section>

    <!-- Inyección de Plástico -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold text-gray-900 mb-2">Inyección de Plástico</h2>
      <p class="text-gray-600 mb-8">Fabricamos piezas de plástico con altos estándares de calidad y precisión.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
          <div class="w-12 h-12 bg-yellow-400 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Maquila de piezas</h3>
          <p class="text-sm text-gray-600">Producción por contrato de piezas de plástico con materia prima del cliente o suministrada por nosotros.</p>
        </div>

        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
          <div class="w-12 h-12 bg-yellow-400 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Apertura de 1,025 mm</h3>
          <p class="text-sm text-gray-600">Máquina de inyección con la mayor capacidad de apertura, permitiendo piezas de gran tamaño — hasta del tamaño de un bote de basura.</p>
        </div>

        <div class="bg-gray-50 rounded-2xl p-6 border border-gray-200">
          <div class="w-12 h-12 bg-yellow-400 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Tampografía</h3>
          <p class="text-sm text-gray-600">Impresión de logos, códigos e información técnica sobre piezas moldeadas con tintas de alta durabilidad.</p>
        </div>
      </div>
    </section>

    <!-- Diferenciadores -->
    <section class="mb-16 bg-gray-50 rounded-2xl p-8 md:p-12">
      <h2 class="text-3xl font-bold text-gray-900 mb-2 text-center">Nuestros diferenciadores</h2>
      <p class="text-gray-600 mb-8 text-center max-w-xl mx-auto">Más que manufactura, ofrecemos soluciones integrales que agregan valor a cada proyecto.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="text-yellow-500 text-3xl font-bold mb-2">01</div>
          <h3 class="font-semibold text-gray-900 mb-1">Diseño</h3>
          <p class="text-sm text-gray-600">Desarrollamos productos desde la conceptualización hasta el diseño detallado.</p>
        </div>
        <div class="text-center">
          <div class="text-yellow-500 text-3xl font-bold mb-2">02</div>
          <h3 class="font-semibold text-gray-900 mb-1">Prototipo</h3>
          <p class="text-sm text-gray-600">Validamos la funcionalidad y el diseño antes de la producción en serie.</p>
        </div>
        <div class="text-center">
          <div class="text-yellow-500 text-3xl font-bold mb-2">03</div>
          <h3 class="font-semibold text-gray-900 mb-1">Soporte técnico</h3>
          <p class="text-sm text-gray-600">Acompañamiento especializado durante todo el ciclo del proyecto.</p>
        </div>
        <div class="text-center">
          <div class="text-yellow-500 text-3xl font-bold mb-2">04</div>
          <h3 class="font-semibold text-gray-900 mb-1">Acompañamiento integral</h3>
          <p class="text-sm text-gray-600">Desde la planeación hasta la fabricación, implementación y seguimiento.</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-niebla-700 rounded-2xl p-8 md:p-12 text-white text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">¿Necesitas un servicio personalizado?</h2>
      <p class="text-[#e7e7e7] mb-6 max-w-xl mx-auto">Nuestro equipo de ingenieros puede asesorarte desde el diseño hasta la producción final.</p>
      <a href="/#contact" class="btn-yellow inline-block bg-yellow-400 text-black font-semibold px-10 py-3 rounded transition-all hover:bg-white hover:text-black hover:border-black hover:border-2 hover:scale-[1.02]">
        Solicitar cotización
      </a>
    </section>
  </main>

  <button id="btn-subir" class="fixed bottom-6 right-6 z-50 bg-yellow-400 text-black w-12 h-12 rounded-full shadow-lg flex items-center justify-center text-2xl font-bold transition-all duration-300 hover:bg-yellow-300 hover:scale-110 opacity-0 pointer-events-none" onclick="window.scrollTo({ top: 0, behavior: 'smooth' })" aria-label="Volver arriba">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3" stroke-linecap="round"><path d="M18 15l-6-6-6 6"/></svg>
  </button>

  <footer class="bg-niebla-700 text-[#e7e7e7]">
    <div class="max-w-7xl mx-auto px-4 py-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <div>
        <h3 class="text-white font-semibold text-lg mb-3">Acabados</h3>
        <ul class="space-y-2 text-sm">
          <li class="flex items-center gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block"></span>Galvanizado en caliente</li>
          <li class="flex items-center gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block"></span>Galvanizado electrolítico</li>
          <li class="flex items-center gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block"></span>Pintura electrostática</li>
          <li class="flex items-center gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block"></span>Tropicalizado</li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold text-lg mb-3">Inyección</h3>
        <ul class="space-y-2 text-sm">
          <li class="flex items-center gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block"></span>Fabricación de moldes</li>
          <li class="flex items-center gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block"></span>Maquila de piezas</li>
          <li class="flex items-center gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block"></span>Apertura 1,025 mm</li>
          <li class="flex items-center gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block"></span>Tampografía</li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold text-lg mb-3">Industrias</h3>
        <ul class="space-y-2 text-sm">
          <li class="flex items-center gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block"></span>Telecomunicaciones</li>
          <li class="flex items-center gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block"></span>Construcción</li>
          <li class="flex items-center gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block"></span>Manufactura</li>
          <li class="flex items-center gap-2"><span class="w-2 h-2 bg-yellow-400 rounded-full inline-block"></span>Eléctrico / Electrónico</li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold text-lg mb-3">Contacto</h3>
        <ul class="space-y-2 text-sm">
          <li><span class="block text-xs">Correo</span><a href="mailto:contacto@metalico.mx" class="hover:text-white transition-colors underline underline-offset-2">contacto@metalico.mx</a></li>
          <li><span class="block text-xs">Teléfono</span><a href="tel:+525581082193" class="hover:text-white transition-colors underline underline-offset-2">55 8108 2193</a></li>
          <li><span class="block text-xs">Oficina</span><span class="text-sm">(55) 5243 – 6900 ext. 9301 / ext. 2201</span></li>
          <li><span class="block text-xs">WhatsApp</span><a href="https://wa.me/525581082193" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors underline underline-offset-2">55 8108 2193</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800">
      <p class="text-center text-xs text-[#e7e7e7] py-4">&copy; 2026 Metalico. Todos los derechos reservados.</p>
    </div>
  </footer>
</Layout>

<script>
  const btn = document.getElementById('btn-subir');
  window.addEventListener('scroll', function () {
    if (window.scrollY > window.innerHeight * 0.5) {
      btn.classList.remove('opacity-0', 'pointer-events-none');
      btn.classList.add('opacity-100');
    } else {
      btn.classList.add('opacity-0', 'pointer-events-none');
      btn.classList.remove('opacity-100');
    }
  });
</script>
