---
import Section from "./Section.astro";
import "../styles/nft.css";
---

<Section
  title="Infraestructura y Maquinaria"
  subtitle="Más de 1,600 m² de planta industrial con 12 líneas de producción"
  color="white"
  id="solutions"
>
  <div slot="contain">
    <div class="nft">
      <div class="main">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-left text-sm">
          <div>
            <strong class="text-white/90 text-base">Infraestructura:</strong><br />
            <span class="text-[#9accff]">• Superficie total: 1,623.59 m²<br />
            • Superficie construida: 1,532.12 m²<br />
            • 12 líneas de producción</span>
          </div>
          <div>
            <strong class="text-white/90 text-base">Maquinaria:</strong><br />
            <span class="text-[#9accff]">
              • Centro de maquinado / Centro de torneado CNC<br />
              • Cortadora CNC / Plasma / Láser en placa y tubo<br />
              • Curvadora / Dobladora de cortina / Oxicorte<br />
              • Erosionadora 3D / Hilo / Penetración<br />
              • Fresadora vertical / Impresión 3D<br />
              • Máquina de inyección / Metalera<br />
              • Prensa troqueladora 250 t / Rectificadora<br />
              • Roladora / Roscadora<br />
              • Soldadura Mig / Soldadura Tig / Torno paralelo
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div slot="footer" class="gap-x-6 flex mx-auto">
    <a
      class="btn-gray border-[3px] border-stone-600 bg-stone-600 text-sm rounded font-medium text-white px-12 py-2 inline-block transition-all hover:bg-yellow-300 hover:text-black hover:scale-[1.02]"
      href="https://wa.me/525581082193?text=Hola%2C%20me%20interesa%20conocer%20m%C3%A1s%20sobre%20su%20equipo%20y%20servicios"
      target="_blank"
      rel="noopener noreferrer"
    >
      Contactar</a
    >
    <a
      class="btn-white bg-white text-sm rounded font-medium px-12 py-2 transition-colors hover:bg-black hover:text-white inline-flex justify-center items-center text-black"
      href="/Capacidad-de-manufactura.xlsx" download
    >
      Descargar capacidades</a
    >
  </div>

  <img
    slot="background"
    alt="Espacio metalúrgico con maquinaria relacionada"
    class="h-full w-full object-cover object-center"
    src="service.avif"
    id="bg-image-solutions"
  />
</Section>

<script>
  function isEdge() {
    if (
      navigator.userAgent.indexOf("Edge") > -1 ||
      navigator.userAgent.indexOf("Edg") > -1
    ) {
      return true;
    } else {
      return false;
    }
  }

  let imageElement = document.querySelector(
    "#bg-image-solutions",
  ) as HTMLImageElement; // TypeScript

  if (isEdge()) {
    imageElement.src = "service.webp";
  } else {
    imageElement.src = "service.avif";
  }
</script>
