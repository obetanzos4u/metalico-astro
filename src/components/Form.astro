<script
  type="text/javascript"
  src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"
></script>
<script type="text/javascript">
  (function () {
    emailjs.init("SsrXxV23cwZnkbb0C");
  })();

  document.addEventListener("DOMContentLoaded", function () {
    const btn = document.getElementById("button");

    btn.addEventListener("click", function (event) {
      event.preventDefault(); // Previene la acción por defecto del ancla

      btn.textContent = "Enviando...";

      const form = document.getElementById("form");
      const serviceID = "service_t2idvpt";
      const templateID = "template_b4pxi59";

      const msg = document.getElementById("form-message");
      msg.className = "form-message";

      emailjs.sendForm(serviceID, templateID, form).then(
        () => {
          btn.textContent = "Enviar mensaje";
          msg.textContent = "Mensaje enviado con éxito";
          msg.classList.add("success");
          form.reset();
        },
        (err) => {
          btn.textContent = "Enviar mensaje";
          msg.textContent = "Error al enviar. Intenta de nuevo.";
          msg.classList.add("error");
        },
      );
    });

    window.onload = function () {
      document.getElementById("form").reset();
    };

    // Este código asume que tienes un elemento en tu HTML para mostrar el nombre del archivo
    // Por ejemplo, un span con id="nombreArchivo"
    document.getElementById("archivo").onchange = function (e) {
      // Obtiene el nombre del archivo seleccionado
      var fileName = e.target.files[0].name;
      // Actualiza el contenido del elemento con el nuevo nombre de archivo
      document.getElementById("nombreArchivo").textContent =
        fileName || "Selecciona tu archivo";
    };

    // Agregar la clase “active” al label del formulario cuando el campo de correo esté activo, puedes usar JavaScript para detectar el enfoque (focus) y desenfoque (blur) del campo de entrada.
    const focusElements = document.querySelectorAll(
      ".activeFocusInput, .activeFocusAnchor",
    );
    const formLabels = document.querySelectorAll(".activeFocusLabel");

    // Asegurarse de que hay la misma cantidad de elementos y labels
    if (focusElements.length === formLabels.length) {
      focusElements.forEach((element, index) => {
        const label = formLabels[index];

        element.addEventListener("focus", () => {
          label.classList.add("active");
        });

        element.addEventListener("blur", () => {
          if (!element.value) {
            label.classList.remove("active");
          }
        });
      });
    } else {
      console.error("El número de elementos y labels no coincide.");
    }

    const toggleArrows = document.querySelectorAll(
      ".form-dropdown__toggle-arrow, .w-toggle-arrow",
    );

    const selectElement = document.getElementById("service_type");
    const labelElement = document.getElementById("service_type_label");

    toggleArrows.forEach((toggleArrow) => {
      toggleArrow.addEventListener("click", function () {
        selectElement.classList.toggle("hidden");
        selectElement.classList.toggle("select-visible");
        selectElement.size = selectElement.classList.contains("select-visible")
          ? selectElement.options.length
          : 1;

        // Añadir o quitar la clase "w--open" para el icono de desplazamiento
        toggleArrow.classList.toggle("w--open");
      });
    });

    // Asegurarse de que se puede seleccionar una opción
    selectElement.addEventListener("change", function () {
      // Actualizar el texto del label con la opción seleccionada
      const selectedOptionText =
        selectElement.options[selectElement.selectedIndex].text;
      labelElement.innerHTML = `${selectedOptionText}`;

      // Añadir clase para cambiar el color del texto a negro
      labelElement.classList.add("selected-option");

      // Ocultar el select después de seleccionar una opción
      selectElement.classList.add("hidden");
      selectElement.classList.remove("select-visible");
      selectElement.size = 1; // Vuelve al tamaño normal después de seleccionar

      // Asegurarse de que el icono de desplazamiento vuelve a su estado original
      toggleArrows.forEach((toggleArrow) => {
        toggleArrow.classList.remove("w--open");
      });
    });
  });

  document.getElementById("message").addEventListener("input", function () {
    const maxChars = 350;
    const textArea = this;
    const charCount = document.getElementById("wordCount");

    if (textArea.value.length > maxChars) {
      textArea.value = textArea.value.substring(0, maxChars);
    }

    charCount.textContent = `${textArea.value.length} / ${maxChars} caracteres`;
  });
</script>
