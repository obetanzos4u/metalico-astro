---
const categorias = [
  {
    titulo: "Herrajes para Redes Aéreas",
    tipos: ["Aéreo accesorios", "Cruceta"],
    img: "herraje-metalico.jpg",
    link: "/productos",
  },
  {
    titulo: "Brazos para Instalación Aérea",
    tipos: ['Brazo "D"', 'Brazo "J" ADSS', "Brazo tangente"],
    img: "extension-metalico.jpg",
    link: "/productos",
  },
  {
    titulo: "Cables Mensajeros",
    tipos: ['Cable mensajero 3/16"', 'Cable mensajero 1/4"', 'Cable mensajero 3/8"'],
    img: "cable-metalico.jpg",
    link: "/productos",
  },
  {
    titulo: "Bases y Soportes",
    tipos: ["Bajada base uso exterior"],
    img: "base-metalico.jpg",
    link: "/productos",
  },
];
---

<section
  id="products"
  class="landing-section relative min-h-screen w-screen flex flex-col items-center justify-center text-white"
  data-header-color="white"
>
  <div class="absolute inset-0 h-full w-full z-0">
    <img class="h-full w-full object-cover object-center" src="products.avif" alt="" />
    <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/60 to-black/80"></div>
  </div>

  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 py-16 flex flex-col items-center">
    <h2 class="text-4xl md:text-5xl font-bold text-white mb-2">Productos</h2>
    <p class="text-sm text-gray-300 mb-10 text-center max-w-xl">
      Equipamiento para redes de telecomunicaciones e infraestructura industrial
    </p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 w-full">
      {categorias.map((cat) => (
        <div class="group relative overflow-hidden rounded-2xl bg-white/10 backdrop-blur-sm border border-white/20 transition-all duration-300 hover:scale-[1.03] hover:bg-white/20">
          <div class="aspect-[5/5] overflow-hidden">
            <img
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
              src={cat.img}
              alt={cat.titulo}
            />
          </div>
          <div class="p-4 flex flex-col gap-1.5">
            <h3 class="text-base md:text-lg font-semibold leading-tight">{cat.titulo}</h3>
            <ul class="text-xs text-gray-300 space-y-0.5">
              {cat.tipos.map((t) => <li class="before:content-['-'] before:mr-1.5 before:text-yellow-400">{t}</li>)}
            </ul>
            {cat.link ? (
              <a
                href={cat.link}
                class="text-xs uppercase tracking-wider text-yellow-400 hover:text-yellow-300 transition-colors font-medium pt-1 inline-block"
              >
                Ver más &rarr;
              </a>
            ) : null}
          </div>
        </div>
      ))}
    </div>

    <a
      href="/productos"
      class="mt-8 inline-block border-[3px] border-stone-600 bg-stone-600 text-sm rounded font-medium text-white px-10 py-2.5 transition-all hover:bg-yellow-400 hover:text-black hover:border-yellow-400 hover:scale-[1.02]"
    >
      Ver catálogo completo &rarr;
    </a>
  </div>
</section>

<style>
  @media (max-width: 767px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .grid > div:nth-child(n+3) {
      display: none;
    }
  }
</style>
