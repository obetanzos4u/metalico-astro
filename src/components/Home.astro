---
import Section from "./Section.astro";
---

<Section
  title="Soluciones Metálicas y Plásticas para la Industria"
  subtitle="Diseño, desarrollo y manufactura — más de 20 años transformando ideas en soluciones reales"
  color="white"
  id="home"
>
  <div slot="footer">
    <a
      class="bg-white text-sm rounded font-medium px-12 py-2 transition-colors hover:bg-black hover:text-white inline-flex justify-center items-center text-black"
      href="#contact"
      aria-label="Cotizar servicio - Ir al formulario de contacto"
      title="Cotiza tu servicio con nosotros"
    >
      Cotizar servicio</a
    >
  </div>

  <img
    slot="background"
    class="object-center object-cover h-full w-full"
    alt=""
    src="home.avif"
  />
</Section>
