---
const { color, title, subtitle, id, showFooterContent, subtitleExtraClass } =
  Astro.props;
const textColor = `text-${color}`;
import FooterMenu from "./FooterMenu.astro";
---

<style>
  @media (max-width: 767px) {
    :global(.slide-footer a:not(:first-child)) {
      display: none !important;
    }
  }
</style>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const mql = window.matchMedia("(max-width: 767px)");
    function hideExtraButtons(matches) {
      document.querySelectorAll(".slide-footer").forEach(wrapper => {
        const links = wrapper.querySelectorAll("a");
        links.forEach((a, i) => {
          a.style.display = matches && i > 0 ? "none" : "";
        });
      });
    }
    hideExtraButtons(mql.matches);
    mql.addEventListener("change", e => hideExtraButtons(e.matches));
  });
</script>

<section
  class="landing-section bg-white min-h-screen w-screen text-center relative"
  data-header-color={color}
  id={id}
>
  <div class="z-30 relative h-full flex flex-col">
    <header>
        <h2 class={`${textColor} max-md:pt-8 md:pt-28 slide-title font-medium`}>
        {title}
      </h2>
      <p class={`${textColor} slide-desc ${subtitleExtraClass}`}>
        {subtitle}
      </p>
    </header>

    <div
      class="slide-content max-md:my-4 max-md:mb-4 md:my-20 md:max-w-[40%] text-center flex justify-center text-base"
    >
      <div
        class="relative
      flex
      flex-col
      items-center
      justify-center
      custom-container"
      >
        <slot name="contain" />
      </div>
    </div>

    <footer class="flex flex-col items-center pb-10 max-md:max-w-[90%] max-md:mx-auto">
      <div class="slide-footer"><slot name="footer" /></div>
      <!-- Contidionally load footer: -->
      {showFooterContent && <FooterMenu />}
    </footer>
  </div>

  <div
    class="absolute top-0 bottom-0 h-full w-full z-10"
    style="background-color: #001F4F"
  >
    <slot name="background" />
  </div>
  <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70 z-20"></div>
</section>
