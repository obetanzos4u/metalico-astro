<style>
  :root {
    --blue-dark: #02021e;
    --yellow: #fdc448;
  }
  .custom-info-contact {
    display: flex;
    width: fit-content;
    grid-column-gap: 2.75rem;
    grid-row-gap: 2.75rem;
    opacity: 1;
    flex-direction: column;
    flex: 0 auto;
    justify-content: flex-start;
    padding-top: 2rem;
    justify-content: space-between;
    transition: opacity 0.4s;
  }

  .heading-1 {
    width: fit-content;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    font-size: 3rem;
    text-align: left;
    font-weight: 500;
    line-height: 0.9;
  }

  @media (min-width: 780px) and (max-width: 1279px) {
    .heading-1 {
      font-size: 2.5rem;
    }
  }

  @media (max-width: 767px) {
    .custom-info-contact {
      display: none;
    }
    .heading-1 {
      font-size: 24px;
    }
  }

  @media (min-width: 1280px) {
    .heading-1 {
      font-size: 5rem;
    }
  }

  .contact__list-wrap {
    grid-column-gap: 4.75rem;
    grid-row-gap: 4.75rem;
    flex-direction: column;
    align-items: center;
    display: flex;
  }
  .icon-small {
    z-index: 2;
    flex: none;
    width: 1rem;
    height: 1rem;
    font-size: 0;
    position: relative;
  }

  .list__item {
    font-size: 1rem;
    line-height: 1.5;
  }

  @media (min-width: 768px) {
    .list__item {
      font-size: 1.25rem;
    }
  }
  .contact-title {
    text-transform: uppercase;
    opacity: 0.7;
    font-size: 1rem;
    line-height: 1.5;
  }
  .book_call {
    width: fit-content;
    display: flex;
    flex-direction: row;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.5;
    text-transform: uppercase;
    border: 1px solid white;
    border-radius: 99px;
    padding: 0.5rem 0.75rem 0.5rem 1.25rem;
    align-items: center;
    justify-content: space-between;
    transition: all 0.4s;
    cursor: pointer;
  }
  .book_call:hover {
    background-color: white;
    color: var(--blue-dark);
  }
  .book_call:hover .button__icons.bg-color-yellow {
    background-color: var(--blue-dark);
    border-color: var(--blue-dark);
    color: var(--yellow);
  }
  .list__item.mod--contact {
    opacity: 1;
    background-image: url("/bullet-icon.png");
    background-position: 0%;
    background-repeat: no-repeat;
    background-size: 1.25rem;
    text-align: initial;
    margin-bottom: 0;
    padding-left: 2rem;
    list-style-type: none;
    transition:
      transform 0.6s,
      opacity 0.4s;
    position: relative;
    transform: translate(0);
  }
  .columns {
    justify-content: space-between;
    align-items: stretch;
    display: flex;
  }

  .list.mod--contact {
    grid-column-gap: 0.875rem;
    grid-row-gap: 0.875rem;
    flex-direction: column;
    padding-left: 0;
    display: flex;
  }
  .contact-mail {
    font-size: 1.25rem;
    font-weight: bold;
    text-align: initial;
  }
  .contact-phone {
    font-size: 1rem;
    text-align: initial;
  }
.contact-link {
  color: inherit;
  text-decoration: underline;
  text-underline-offset: 2px;
  transition: opacity 0.2s;
}
  .contact-link:hover {
    opacity: 0.7;
  }
  .columns.mod--contact-video {
    grid-column-gap: 1.5rem;
    opacity: 1;
    justify-content: flex-start;
    align-items: center;
    transition:
      transform 0.6s,
      opacity 0.4s;
    transform: translate(0);
  }
  .columns__col.mod--contact-video {
    grid-row-gap: 1.25rem;
    flex-direction: column;
    flex: 0 auto;
    justify-content: center;
    align-items: flex-start;
    display: flex;
  }
  .contact__video-address {
    grid-column-gap: 1rem;
    flex-flow: row;
    align-items: center;
    display: flex;
  }

  .contact-info-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-left: 1rem;
  }

  .contact-video {
    width: 300px;
    height: auto;
    flex-shrink: 0;
    display: block;
  }
  .hf-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 1;
    border-radius: 12px;
    overflow: hidden;
    box-shadow:
      0 0 0 2px rgba(255,255,255,0.9),
      0 0 0 4px rgba(180,180,190,0.7),
      0 0 0 6px rgba(255,255,255,0.4),
      0 0 0 7px rgba(0,0,0,0.3),
      inset 0 0 24px rgba(0,0,0,0.7);
  }
  .hf-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 12px;
    border: 2px solid rgba(255,255,255,0.15);
    z-index: 3;
    pointer-events: none;
  }
  .hf-frame-bg {
    position: absolute;
    inset: 0;
    background: transparent;
    z-index: 0;
  }
  .hf-streak {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none; z-index: 1;
  }
  .hf-streak-1 {
    background: linear-gradient(135deg, transparent 0%, transparent 35%, rgba(255,255,255,0.08) 40%, rgba(255,255,255,0.15) 42%, transparent 44%, transparent 100%);
  }
  .hf-streak-2 {
    background: linear-gradient(135deg, transparent 0%, transparent 25%, rgba(255,255,255,0.04) 30%, rgba(255,255,255,0.10) 32%, transparent 34%, transparent 100%);
  }
  .hf-streak-3 {
    background: linear-gradient(135deg, transparent 0%, transparent 50%, rgba(255,255,255,0.06) 55%, rgba(255,255,255,0.12) 57%, transparent 59%, transparent 100%);
  }
  .hf-grain {
    position: absolute; inset: 0;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    background-repeat: repeat; background-size: 256px 256px;
    z-index: 1; mix-blend-mode: overlay;
  }
  .hf-chrome-gloss {
    position: absolute; top: 0; left: 0; right: 0; height: 60%;
    border-radius: 12px 12px 0 0;
    background: linear-gradient(180deg, rgba(255,255,255,0.10) 0%, rgba(255,255,255,0.06) 20%, rgba(255,255,255,0.02) 50%, transparent 100%);
    z-index: 2; pointer-events: none;
  }
  .hf-chrome-reflect {
    position: absolute; bottom: 0; left: 10%; right: 10%; height: 20%;
    background: linear-gradient(0deg, rgba(255,255,255,0.04) 0%, transparent 100%);
    border-radius: 0 0 12px 12px;
    z-index: 2; pointer-events: none;
  }
  .hf-fresnel-left {
    position: absolute; top: 10%; left: 0; bottom: 10%; width: 2px;
    background: linear-gradient(180deg, transparent 0%, rgba(255,255,255,0.15) 30%, rgba(255,255,255,0.05) 50%, rgba(255,255,255,0.12) 70%, transparent 100%);
    border-radius: 2px; z-index: 3; pointer-events: none;
  }
  .hf-fresnel-right {
    position: absolute; top: 15%; right: 0; bottom: 15%; width: 2px;
    background: linear-gradient(180deg, transparent 0%, rgba(255,255,255,0.08) 20%, rgba(255,255,255,0.02) 50%, rgba(255,255,255,0.06) 80%, transparent 100%);
    border-radius: 2px; z-index: 3; pointer-events: none;
  }
  .hf-frame-shadow {
    position: absolute; inset: 0;
    border-radius: 12px;
    box-shadow: inset 0 24px 32px -16px rgba(0,0,0,0.8), inset 0 -16px 24px -12px rgba(0,0,0,0.5);
    z-index: 2; pointer-events: none;
  }
  .hf-logo {
    position: absolute;
    left: 50%; top: 50%;
    transform: translate(-50%, -50%);
    width: 60%;
    height: auto;
    z-index: 4;
    display: block;
    filter: drop-shadow(0 0 8px rgba(255,255,255,0.08)) drop-shadow(0 2px 6px rgba(0,0,0,0.4));
  }
  .hf-glow {
    position: absolute;
    left: 50%; top: 50%;
    width: 80%; height: 60%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(ellipse, rgba(255,255,255,0.03) 0%, transparent 70%);
    z-index: 3; pointer-events: none;
    animation: hf-pulse 4s ease-in-out infinite;
    animation-play-state: paused;
  }
  .hf-frame.is-visible .hf-glow {
    animation-play-state: running;
  }
  .hf-sweep {
    position: absolute; top: -20%; left: -80%;
    width: 60%; height: 140%;
    background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.02) 25%, rgba(255,255,255,0.12) 40%, rgba(255,255,255,0.20) 45%, rgba(255,255,255,0.12) 50%, rgba(255,255,255,0.02) 55%, transparent 100%);
    transform: skewX(-20deg);
    z-index: 5; pointer-events: none;
    animation: hf-sweep1 6s ease-in-out infinite;
    animation-play-state: paused;
  }
  .hf-frame.is-visible .hf-sweep {
    animation-play-state: running;
  }
  .hf-sweep-2 {
    position: absolute; top: -30%; left: -100%;
    width: 80%; height: 160%;
    background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.01) 30%, rgba(255,255,255,0.06) 45%, rgba(255,255,255,0.02) 55%, transparent 100%);
    transform: skewX(-15deg);
    z-index: 5; pointer-events: none;
    animation: hf-sweep2 8s ease-in-out infinite;
    animation-play-state: paused;
  }
  .hf-frame.is-visible .hf-sweep-2 {
    animation-play-state: running;
  }
  @keyframes hf-pulse {
    0%, 100% { opacity: 0.3; scale: 1; }
    50% { opacity: 0.5; scale: 1.05; }
  }
  @keyframes hf-sweep1 {
    0%, 100% { opacity: 0; transform: skewX(-20deg) translateX(0); }
    10% { opacity: 1; }
    30% { opacity: 0; transform: skewX(-20deg) translateX(2600px); }
  }
  @keyframes hf-sweep2 {
    0%, 100% { opacity: 0; transform: skewX(-15deg) translateX(0); }
    15% { opacity: 0.6; }
    40% { opacity: 0; transform: skewX(-15deg) translateX(3000px); }
  }

  @media (max-width: 767px) {
    .contact-video {
      display: none;
    }
  }
  .button__icons.bg-color-yellow {
    border-color: var(--yellow);
    background-color: var(--yellow);
    color: var(--blue-dark);
  }
  .button__icons {
    border-radius: 50%;
    flex: none;
    justify-content: center;
    align-items: center;
    margin-left: 16px;
    width: 2rem;
    height: 2rem;
    transition: all 0.4s;
    display: flex;
    position: relative;
    overflow: hidden;
    transform: translate(0);
  }
</style>

<script>
  const el = document.querySelector('.hf-frame');
  if (el) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          el.classList.add('is-visible');
        } else {
          el.classList.remove('is-visible');
        }
      });
    }, { threshold: 0.3 });
    observer.observe(el);
  }
</script>
