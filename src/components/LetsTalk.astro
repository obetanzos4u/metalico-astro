---
const {
  color,
  title,
  subtitle,
  id,
  showFooterContent,
  subtitleExtraClass,
  mostrarFormulario,
} = Astro.props;
const textColor = `text-${color}`;
import CustomInfoContain from "./CustomInfoContain.astro";
import CustomContainer from "./CustomContainer.astro";
---

<section
  class="landing-section bg-white h-screen w-screen text-center overflow-hidden relative"
  data-header-color={color}
  id={id}
>
  <div class="z-30 relative h-full flex flex-col">
    <header>
      <h2 class={`${textColor} pt-20 text-[40px] font-medium`}>
        {title}
      </h2>
      <p class={`${textColor} text-sm ${subtitleExtraClass} mb-4`}>
        {subtitle}
      </p>
    </header>
    <div class="container-contact mt-4">
      <div class="flex flex-row w-[90%] justify-between mx-auto">
        <CustomInfoContain />
        <CustomContainer mostrarFormulario={mostrarFormulario} />
      </div>
    </div>
    <footer class="flex flex-col items-center pb-10">
      <slot name="footer" />
    </footer>
  </div>
  <div class="absolute top-0 bottom-0 h-full w-full z-10">
    <slot name="background" />
  </div>
</section>
