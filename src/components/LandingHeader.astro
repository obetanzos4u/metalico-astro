---
import Logo from "./Logo.astro";
---

<header
  id="landing-header"
  class="py-3 pt-7 px-[5%] flex items-center w-full justify-between z-40 text-white"
>
  <div class="flex flex-grow basis-0">
    <a href="./">
    <img
      class="h-8"
      alt="arrow icon"
      src="/logo_metalico.avif"
    /></a>
  </div>

  <nav class="hidden lg:block sm:hidden">
    <ul
      class="flex text-base [&>li>a]:transition-all [&>li>a]:duration-300 [&>li>a]:text-current [&>li>a]:font-medium [&>li>a]:inline-block [&>li>a]:px-4 [&>li>a]:py-2 [&>li>a]:hover:text-yellow-400"
    >
      <li><a href="#about">¿Quienes somos?</a></li>
      <li><a href="#service">Servicios</a></li>
      <!-- <li><a href="#solutions">Equipo</a></li> -->
      <li><a href="#production">Manofactura</a></li>
      <li><a href="#products">Productos</a></li>
      <li><a href="#contact">Contacto</a></li>
    </ul>
  </nav>

  <nav class="flex flex-grow justify-end basis-0">
    <ul
      class="flex text-sm [&>li>a]:transition-colors [&>li>a]:duration-500 [&>li>a]:text-current [&>li>a]:font-medium [&>li>a]:inline-block [&>li>a]:px-4 [&>li>a]:py-2"
    >
      <li class="hidden lg:block sm:hidden"><a class="hover:text-yellow-400" href="/tienda">Tienda</a></li>
      <li class="lg:hidden">
        <button id="menu-btn" class="p-2 cursor-pointer" aria-label="Abrir menú">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </li>
    </ul>
  </nav>

  <nav
    id="modal-menu"
    class="hidden lg:hidden flex flex-col bg-white fixed top-0 left-0 right-0 bottom-0"
  >
    <button id="close-btn" class="w-screen flex justify-end p-5">
      <img class="text-black h-6" src="/close-icon.svg" alt="close image" />
    </button>
    <ul
      class="flex flex-col mt-4 [&>li>a]:transition-colors [&>li]:m-3 [&>li>a]:flex [&>li>a]:items-center [&>li>a]:gap-2 [&>li>a]:duration-200 [&>li>a]:text-black [&>li>a]:font-medium [&>li>a]:px-6 [&>li>a]:py-3 [&>li>a]:rounded-md [&>li>a]:w-full"
    >
      <li>
        <a class="hover:bg-slate-100" href="#about"
          >¿Quienes somos?<img
            class="h-5"
            alt="arrow icon"
            src="/chevron-icon.svg"
          /></a
        >
      </li>
      <li>
        <a class="hover:bg-slate-100" href="#service"
          >Servicios<img class="h-5" alt="arrow icon" src="/chevron-icon.svg" /></a
        >
      </li>
      <li>
        <a class="hover:bg-slate-100" href="#products"
          >Productos terminados<img
            class="h-5"
            alt="arrow icon"
            src="/chevron-icon.svg"
          /></a
        >
      </li>
            <!-- <li>
        <a class="hover:bg-slate-100" href="#solutions"
          >Equipo<img class="h-5" alt="arrow icon" src="/chevron-icon.svg" /></a
        >
      </li> -->
      <li>
        <a class="hover:bg-slate-100" href="#production"
          >Manofactura<img
            class="h-5"
            alt="arrow icon"
            src="/chevron-icon.svg"
          /></a
        >
      </li>
      <li>
        <a class="hover:bg-slate-100 border-t border-gray-200 mt-2 pt-4" href="/tienda"
          >Tienda<img class="h-5" alt="arrow icon" src="/chevron-icon.svg" /></a
        >
      </li>
      <li>
        <a class="hover:bg-slate-100" href="#contact"
          >Contacto<img class="h-5" alt="arrow icon" src="/chevron-icon.svg" /></a
        >
      </li>
    </ul>
  </nav>

  <div
    id="menu-backdrop"
    class={`
      absolute bg-yellow-400/20 backdrop-blur-lg rounded
      translate-x-[var(--left)] translate-y-[var(--top)]
      left-0 top-0
      w-[var(--width)] h-[var(--height)]
      transition-all duration-500
      ease-in-out opacity-0 -z-10
    `}
  >
  </div>
</header>

<script>
  const menuBtn = document.getElementById("menu-btn");
  const modalMenu = document.querySelector("#modal-menu");
  const menuItems = modalMenu?.querySelectorAll("li > a");
  const closeBtn = document.querySelector("#close-btn");

  function openMenu() {
    modalMenu?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    modalMenu?.classList.add("hidden");
    document.body.style.overflow = "";
  }

  menuBtn?.addEventListener("click", openMenu);
  closeBtn?.addEventListener("click", closeMenu);
  menuItems?.forEach((item) => {
    item.addEventListener("click", closeMenu);
  });
</script>

<script>
  const listItem = document.querySelectorAll("#landing-header li");
  const menuBackDrop = document.querySelector("#menu-backdrop") as HTMLElement;

  listItem.forEach((item) => {
    item.addEventListener("mouseenter", () => {
      const { left, top, width, height } = item.getBoundingClientRect();

      menuBackDrop.style.setProperty("--left", `${left}px`);
      menuBackDrop.style.setProperty("--top", `${top}px`);
      menuBackDrop.style.setProperty("--width", `${width}px`);
      menuBackDrop.style.setProperty("--height", `${height}px`);

      menuBackDrop.style.opacity = "1";
      menuBackDrop.style.visibility = "visible";
    });

    item.addEventListener("mouseleave", () => {
      menuBackDrop.style.opacity = "0";
      menuBackDrop.style.visibility = "hidden";
    });
  });
</script>

<script>
  const headerEl = document.querySelector("#landing-header") as HTMLElement;

  const observerOptions = {
    root: null,
    rootMargin: "0px", // en cuanto se vea el elemento
    threshold: 0.9, // porcentaje de visibilidad
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      const { isIntersecting } = entry;
      if (isIntersecting) {
        const color = entry.target.getAttribute("data-header-color");
        headerEl.style.color = color;
      }
    });
  }, observerOptions);

  const sectionElements = document.querySelectorAll(".landing-section");
  sectionElements.forEach((section) => observer.observe(section));
</script>
